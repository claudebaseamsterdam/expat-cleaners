RESEND_API_KEY=
NEXT_PUBLIC_SITE_URL=https://expatcleaners.nl
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel ID. When missing, src/lib/pixel.ts logs to
# the browser console in dev and is a no-op in prod.
NEXT_PUBLIC_META_PIXEL_ID=
# Optional: when "false", the booking flow uses the live agent layer
# instead of the deterministic mock. The live integration is not wired
# yet — leaving this unset (or "true") keeps /api/booking returning
# successful mock responses.
USE_MOCK_AGENTS=true
